# Environment Variables for NLP Project Frontend

# API Base URL - Update this to your backend deployment URL
VITE_API_BASE_URL=https://nlp-backend.itclub.asmitphuyal.com.np

# Port configuration (default: 8009)
PORT=8009

# Dev proxy target for Vite's /api proxy in development.
# Use 8000 when running backend via python app.py, or 8007 for Docker.
VITE_DEV_PROXY_TARGET=http://localhost:8000

# For local development, uncomment the line below:
# VITE_API_BASE_URL=http://localhost:8007

# Note: If backend has SSL certificate issues, users may need to 
# manually accept the certificate by visiting the backend URL directly
